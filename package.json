{
  "name": "piekarzynka",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "test": "ng test",
    "start": "ng serve -c development",
    "build": "ng build -c production --base-href https://johngtka.github.io/Piekarzynka/",
    "watch": "ng build --watch --configuration development",
    "format": "prettier --write ./**/*.{ts,json,html,css}",
    "update": "npm update",
    "prepare": "husky install",
    "prebuild": "standard-version",
    "postbuild": "git push --follow-tags && npx angular-cli-ghpages --dir=dist/piekarzynka",
    "frameupdate": "ng update"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.3",
    "@angular/cli": "^20.3.3",
    "@angular/compiler-cli": "^20.3.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}
